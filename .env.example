# ─────────────────────────────────────────────────────────────────────────────
# Gen SEA Summit 2026 — environment template
#
# Copy to `.env.local` and fill in the real values.
# On Vercel, paste each var into Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────


# === Email (Resend) ========================================================
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=team@seabridge.space

# Logo at the top of every email. Leave blank to use the default
# /genseasummit-logo.png from /public.
EMAIL_LOGO_URL=

# === Email signature (sender sign-off) =====================================
# OPTIONAL. If EMAIL_SIGNATURE_NAME is set, every transactional email ends
# with the salutation + name + title pattern:
#
#     Yours sincerely,
#     Mr. Kananate Watewitee
#     Head of Business Partnerships  ·  SEA Bridge Team
#
# If EMAIL_SIGNATURE_NAME is omitted, falls back to a generic team sign-off.
EMAIL_SIGNATURE_NAME=
EMAIL_SIGNATURE_TITLE=
EMAIL_SIGNATURE_ORG=

# === Email corporate footer (the contact-info block at the bottom) =========
# All optional — sensible SEA Bridge defaults are baked in.
EMAIL_SENDER_COMPANY=SEA Bridge
EMAIL_SENDER_PARENT=Really Corp.
EMAIL_SENDER_WEBSITE=https://seabridge.space
EMAIL_SENDER_CONTACT=team@seabridge.space
EMAIL_SENDER_PHONE=(+66) 919946459
EMAIL_SENDER_CHANNELS_URL=https://www.openlink.co/seabridge


# === Public application URL ===============================================
NEXT_PUBLIC_APP_URL=https://gensea-summit-delegates-exclusive-f.vercel.app


# === GVP Bootcamp + Team Flow ==============================================
GVP_BOOTCAMP_ENROLL_URL=
TEAM_FLOW_INVITE_URL=


# === Google Sheets persistence (Apps Script) ==============================
# See docs/apps-script.md for setup. Do NOT use special chars in the secret —
# stick to letters, numbers, hyphens, underscores. Avoid $ # ! ( ) etc.
GSHEET_WEBHOOK_URL=
GSHEET_SHARED_SECRET=
